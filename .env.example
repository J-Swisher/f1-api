# Copy to .env and adjust. The API/REPL read these on startup.

# Directory containing the BUILT f1-db SQLite files (f1.db, f1_telemetry.db).
# The submodule (external/f1-db) ships code only, so point this at your built data.
F1DB_DATA_DIR=C:\Users\josep\repos\f1-db\data

# Optional explicit overrides (otherwise derived from F1DB_DATA_DIR):
# F1DB_CORE_PATH=C:\Users\josep\repos\f1-db\data\f1.db
# F1DB_TELEMETRY_PATH=C:\Users\josep\repos\f1-db\data\f1_telemetry.db

# The terminal's OWN app database (separate from the read-only f1-db).
APP_DB_PATH=data/f1_terminal.db

# Comma-separated CORS origins allowed to call the API (your React dev server).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
